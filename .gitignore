# ==============================
# SECRETS (NEVER COMMIT)
# ==============================
.env*
.mcp.json*
*.backup
**/*token*
**/*tokens*
**/*oauth*
**/*credentials*
**/*.key
**/*.keys.json

# ==============================
# OS / EDITOR
# ==============================
.DS_Store
Thumbs.db
.vscode/
.idea/

# ==============================
# PYTHON
# ==============================
__pycache__/
*.pyc

# ==============================
# NODE / MCP TOOLS
# ==============================
tools/**/node_modules/
tools/**/.cache/
tools/**/.npm/
tools/**/npm-debug.log*

# ==============================
# PLAYWRIGHT CACHE
# ==============================
.playwright-mcp/

# ==============================
# DROPBOX / DEMO NOISE
# ==============================
dropbox/
dropbox/_processed/

# ==============================
# VAULT RUNTIME (DO NOT COMMIT LIVE DATA)
# ==============================
AI_Employee_Vault/Inbox/
AI_Employee_Vault/In_Progress/
AI_Employee_Vault/Needs_Action/
AI_Employee_Vault/Done/
AI_Employee_Vault/Accounting/

# Ignore live logs (we commit snapshots in evidence/)
AI_Employee_Vault/Logs/

# Ignore temp artifacts
AI_Employee_Vault/Artifacts/
AI_Employee_Vault/Completed/

# ==============================
# LOCAL / TEMP BACKUPS
# ==============================
AI_Employee_Vault/*.bak.*
AI_Employee_Vault/Logs/*.bak.*

# Ignore runtime action logs (we store proof in evidence/)
AI_Employee_Vault/Logs/action_log_*.jsonl

# ==============================
# SPECIAL LOCAL FOLDERS (DO NOT COMMIT)
# ==============================
AI_Employee_Vault/Heckathon 0 evidence/
AI_Employee_Vault/**/freeze/
AI_Employee_Vault/**/evidence/

# ==============================
# ALLOW SAFE STRUCTURE (IMPORTANT)
# ==============================
!AI_Employee_Vault/
!AI_Employee_Vault/Plans/
!AI_Employee_Vault/Approved/
!AI_Employee_Vault/Pending_Approval/
!AI_Employee_Vault/Rejected/
!AI_Employee_Vault/Briefings/

# ==============================
# KEEP GOLD EVIDENCE (CRITICAL)
# ==============================
!evidence/
!evidence/**